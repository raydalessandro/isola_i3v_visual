# Chiave API fal.ai — obbligatoria
# Registrati su https://fal.ai → API Keys
FAL_KEY=your_fal_key_here

# Chiave API OpenAI — opzionale, necessaria solo se usi openai_image_gen.py
# (alternativa a Flux: text-to-image + edit_image image-to-image)
# Registrati su https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
